# API Keys
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Plate Recognizer Snapshot Cloud (optional ALPR service)
# Set PLATERECOGNIZER_TOKEN to enable cloud-based plate recognition in the RTSP worker.
# When set, the worker will send JPEG frames to Snapshot Cloud first, then fall back to local OCR if needed.
#PLATERECOGNIZER_TOKEN=YOUR_PLATE_RECOGNIZER_TOKEN_HERE
#PLATERECOGNIZER_ENDPOINT=https://api.platerecognizer.com/v1/plate-reader/
#USE_PLATERECOGNIZER=1

# YOLO Model Weights (vehicle detection only; plate extraction uses Gemini)
# On Windows (example):
# YOLO_VEHICLE_WEIGHTS=C:\Projects\LedgerMonitor\server\models\weights\yolov8n.pt
#
# On Linux/macOS (example):
# YOLO_VEHICLE_WEIGHTS=/srv/ledger-monitor/server/models/weights/yolov8n.pt

# Server Configuration
PORT=3001

# Admin user (for create-admin-user.js script only - do not use in production .env)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your_secure_password
# ADMIN_NAME=Admin User

# SMTP for activation emails (optional - if not set, activation emails are logged to console only)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
# MAIL_FROM=ViolationLedger <noreply@example.com>

#
# Legacy Infobip/Viber configuration has been removed. All notifications now use iProgSMS SMS only.

# Camera URL
# CAMERA_URL=Your camera URL here

# go2rtc RTSP base URL for server-side detection (Option C)
# Server captures frames from RTSP and runs YOLO - no client frame upload.
# Default: rtsp://127.0.0.1:8554 (go2rtc default RTSP port)
# GO2RTC_RTSP_BASE=rtsp://127.0.0.1:8554

# iProgSMS configuration (SMS)
# IPROGSMS_API_TOKEN=your_iprogsms_api_token_here
# Optional overrides:
# IPROGSMS_BASE_URL=https://www.iprogsms.com
# SMS_MAX_LENGTH=160