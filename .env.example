# Google Maps JavaScript API key (Geospatial Analytics card: map + Geometry for jurisdiction).
# Enable “Maps JavaScript API” and load the geometry library (libraries=geometry).
# VITE_GOOGLE_MAPS_API_KEY=

# Show “Add test warning” on Dashboard / Warnings (default: on in Vite dev only)
# VITE_SHOW_TEST_WARNING_BUTTON=true

# Frontend env (used at build time for production)
# For same-domain deployment, use /api so the app talks to your server.
# VITE_API_URL=/api

# Go2RTC WebSocket base URL (live camera WebRTC). IMPORTANT: Vite inlines this at *build* time.
# If you set a LAN URL here and run `vite build`, browsers will keep using that IP forever until you rebuild.
# Never point production builds at 192.168.x.x unless users are only on that LAN.
#
# Pick one:
# - Same host as this app, with Node/Express proxying /go2rtc → local go2rtc (see server/server.js):
#     VITE_GO2RTC_WS_URL=/go2rtc
# - Go2RTC on its own HTTPS host (e.g. Cloudflare tunnel to go2rtc; app stays on violationledger.com):
#     VITE_GO2RTC_WS_URL=https://cam.violationledger.com
#   Same as: npm run build:prod:cam-tunnel
#   (browser uses wss://cam.violationledger.com/...; path is still /api/ws on that host)
# - Leave unset: on HTTPS the app defaults to wss://<current-host>/go2rtc (good if the SPA and /go2rtc proxy share the same origin)
#
# HTTPS: use https:// or wss:// or a leading / — do not use ws:// on an HTTPS page.
# Only set this if you need to disable live streams / detection WebSockets (default: streams on)
# VITE_DISABLE_WS=true

# Optional: where users should be sent after account activation
# Example: VITE_LOGIN_URL=https://your-domain.com/login
# Leave unset to use the local SPA route (/login)
# VITE_LOGIN_URL=/login

# Optional: login URL included in account emails and post-setup redirects
# Example: LOGIN_URL=https://your-domain.com/login
# If unset, the email falls back to ${APP_URL}/login
# LOGIN_URL=http://localhost:5173/login

# Local Vite only: where to proxy /go2rtc (must match go2rtc api.listen, default http://127.0.0.1:1984)
# GO2RTC_PROXY_TARGET=http://127.0.0.1:1984
