# Show “Add test warning” on Dashboard / Warnings (default: on in Vite dev only)
# VITE_SHOW_TEST_WARNING_BUTTON=true

# Frontend env (used at build time for production)
# For same-domain deployment, use /api so the app talks to your server.
# VITE_API_URL=/api

# Go2RTC WebSocket URL (for live camera streams; set when building if using a different host/path)
# Recommended with Nginx proxy: VITE_GO2RTC_WS_URL=wss://your-domain.com/go2rtc
# Only set this if you need to disable live streams / detection WebSockets (default: streams on)
# VITE_DISABLE_WS=true

# Optional: where users should be sent after account activation
# Example: VITE_LOGIN_URL=https://your-domain.com/login
# Leave unset to use the local SPA route (/login)
# VITE_LOGIN_URL=/login

# Optional: login URL included in account emails and post-setup redirects
# Example: LOGIN_URL=https://your-domain.com/login
# If unset, the email falls back to ${APP_URL}/login
# LOGIN_URL=http://localhost:5173/login

# Local Vite only: where to proxy /go2rtc (must match go2rtc api.listen, default http://127.0.0.1:1984)
# GO2RTC_PROXY_TARGET=http://127.0.0.1:1984
